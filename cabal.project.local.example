-- Example cabal.project.local for MUMPS_SEQ integration
-- Normally generated by gen-cabal-config.sh or build.sh
-- Copy this to cabal.project.local and adjust paths as needed

optimization: 2

-- MUMPS_SEQ paths (Debian/Ubuntu: apt install libmumps-seq-dev)
extra-lib-dirs:
    /usr/lib/x86_64-linux-gnu

extra-include-dirs:
    /usr/include
