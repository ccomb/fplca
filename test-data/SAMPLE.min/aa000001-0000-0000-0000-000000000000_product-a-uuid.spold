<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="aa000001-0000-0000-0000-000000000000" activityNameId="aa000001-0000-0000-0000-000000000000" type="1">
        <activityName xml:lang="en">market for product A</activityName>
        <generalComment>
          <text xml:lang="en" index="0">Market activity A: self-loop test. Inputs 0.1 kg of its own product and 0.8 kg from B.</text>
        </generalComment>
      </activity>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <timePeriod startDate="2011-01-01" endDate="2024-12-31" isDataValidForEntirePeriod="true"/>
    </activityDescription>
    <flowData>
      <!-- Output: Product A (reference product) -->
      <intermediateExchange id="out-1" unitId="unit-kg" amount="1.0" intermediateExchangeId="product-a-uuid" productionVolumeAmount="1000.0">
        <name xml:lang="en">product A</name>
        <unitName xml:lang="en">kg</unitName>
        <outputGroup>0</outputGroup>
      </intermediateExchange>

      <!-- Self-loop: Activity A inputs 0.1 kg of its own product A -->
      <intermediateExchange id="in-1" unitId="unit-kg" amount="0.1" intermediateExchangeId="product-a-uuid" activityLinkId="aa000001-0000-0000-0000-000000000000">
        <name xml:lang="en">product A</name>
        <unitName xml:lang="en">kg</unitName>
        <inputGroup>5</inputGroup>
      </intermediateExchange>

      <!-- Input: 0.8 kg product B from activity B -->
      <intermediateExchange id="in-2" unitId="unit-kg" amount="0.8" intermediateExchangeId="product-b-uuid" activityLinkId="bb000002-0000-0000-0000-000000000000">
        <name xml:lang="en">product B</name>
        <unitName xml:lang="en">kg</unitName>
        <inputGroup>5</inputGroup>
      </intermediateExchange>
    </flowData>
    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
      </representativeness>
    </modellingAndValidation>
    <administrativeInformation>
      <fileAttributes defaultLanguage="en" creationTimestamp="2025-01-01T00:00:00" lastEditTimestamp="2025-01-01T00:00:00"/>
    </administrativeInformation>
  </childActivityDataset>
</ecoSpold>
